---
import { site } from "../data/site";
---

<a
  href={site.whatsappHref}
  data-wa
  target="_blank"
  rel="noopener noreferrer"
  class="btn-float-wa"
  aria-label={site.whatsappLabel}
  ><svg class="wa-icon" aria-hidden="true" focusable="false"><use href="#wa-symbol"></use></svg></a
>

<footer id="footer" class="footer">
  <h2>Tu primera clase es gratis, sin compromiso.</h2>
  <a
    href={site.whatsappHref}
    data-wa
    target="_blank"
    rel="noopener noreferrer"
    class="btn btn-invert"
    aria-label={site.whatsappLabel}
    >Escríbeme por WhatsApp <svg class="wa-icon" aria-hidden="true" focusable="false"><use href="#wa-symbol"></use></svg
    ></a
  >
  <p class="copyright">
    &copy; <span id="yr"></span> TRX Concept. Todos los derechos reservados.
  </p>
  <p class="site-credit">
    Sitio web desarrollado con <svg class="heart-icon" viewBox="0 0 640 640" aria-hidden="true"
      ><path
        fill="currentColor"
        d="M305 151.1L320 171.8L335 151.1C360 116.5 400.2 96 442.9 96C516.4 96 576 155.6 576 229.1L576 231.7C576 343.9 436.1 474.2 363.1 529.9C350.7 539.3 335.5 544 320 544C304.5 544 289.2 539.4 276.9 529.9C203.9 474.2 64 343.9 64 231.7L64 229.1C64 155.6 123.6 96 197.1 96C239.8 96 280 116.5 305 151.1z"
      ></path></svg
    ><br />por
    <a
      href="https://agenciachucao.cl/?utm_source=trxconcept.cl&utm_medium=referral&utm_campaign=credit_footer"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Abrir el sitio de Agencia Chucao en una pestaña nueva"
    >
      Agencia Chucao</a
    >.
  </p>
  <div class="footer-legal">
    <a
      href={site.instagram}
      target="_blank"
      rel="noopener noreferrer me"
      aria-label="Seguir TRX Concept en Instagram"
      class="footer-social-link">@trxconcept</a
    >
    {site.legal.map((item) => <a href={item.href}>{item.label}</a>)}
    <button class="cookie-manage-btn" id="cookie-manage-btn" type="button">Gestionar preferencias de cookies</button>
  </div>
</footer>
