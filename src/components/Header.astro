---
import { site } from "../data/site";
import WhatsAppLink from "./WhatsAppLink.astro";

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";
const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
  <nav class="header-inner container">
    <a href="/" class="brand" aria-label="TRX Concept">
      <img src="/assets/logos/trx-concept-logo-.svg" alt="" aria-hidden="true" width="100" height="100" />
      <span class="logo">TRX Concept</span>
    </a>
    <ul class="nav-list" id="nav-main">
      {
        site.nav.map((item) => {
          const isCurrent = normalizePath(item.href) === currentPath;
          return (
            <li>
              <a href={item.href} aria-current={isCurrent ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
    <WhatsAppLink href={site.whatsappHref} message={site.whatsappDefaultMessage} class="btn btn-whatsapp">
      Evaluación gratis
    </WhatsAppLink>
    <button class="nav-toggle-btn" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-main">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>
