---
import { site } from '../data/site';

const normalizePath = (path: string) => path.replace(/\/+$/, '') || '/';
const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
  <nav class="header-inner container">
    <a href="/" class="brand" aria-label="TRX Concept (Inicio)">
      <img src="/assets/logos/trx-concept-logo-.svg" alt="" aria-hidden="true" width="100" height="100" />
      <span class="logo">TRX Concept</span>
    </a>
    <ul class="nav-list" id="nav-main">
      {site.nav.map((item) => {
        const isCurrent = normalizePath(item.href) === currentPath;
        return (
          <li>
            <a href={item.href} aria-current={isCurrent ? 'page' : undefined}>{item.label}</a>
          </li>
        );
      })}
    </ul>
    <a
      href={site.whatsappHref}
      data-wa
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-whatsapp"
      aria-label={site.whatsappLabel}
    >Escríbeme <svg class="wa-icon" aria-hidden="true" focusable="false"><use href="#wa-symbol" /></svg></a>
    <button class="nav-toggle-btn" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-main">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>
