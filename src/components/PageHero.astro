---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import { site } from "../data/site";

type Crumb = { name: string; item: string };

export type PageHeroData = {
  title: string;
  /** May contain inline HTML (e.g. links). */
  description?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  /** Photo credit HTML (attribution), shown bottom-right on image heroes. */
  credit?: string;
};

interface Props {
  hero: PageHeroData;
  breadcrumb?: Crumb[];
}

const { hero, breadcrumb } = Astro.props;
const { title, description, image, imageAlt, credit } = hero;

// Breadcrumb items store absolute URLs (for JSON-LD); render them as local paths.
const crumbHref = (item: string) => (item.startsWith(site.url) ? new URL(item).pathname : item);
---

<header class:list={["page-hero", { "page-hero--image": image }]}>
  {
    image && (
      <div class="page-hero-media">
        <Picture
          src={image}
          alt={imageAlt ?? ""}
          formats={["avif", "webp"]}
          fallbackFormat="webp"
          quality={60}
          widths={[768, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    )
  }
  <div class="container page-hero-inner">
    {
      breadcrumb && breadcrumb.length > 0 && (
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
          <ol>
            {breadcrumb.map((crumb, index) => (
              <li>
                {index === breadcrumb.length - 1 ? (
                  <span aria-current="page">{crumb.name}</span>
                ) : (
                  <a href={crumbHref(crumb.item)}>{crumb.name}</a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    <h1>{title}</h1>
    {description && <p set:html={description} />}
  </div>
  {credit && <p class="hero-credit" set:html={credit} />}
</header>
