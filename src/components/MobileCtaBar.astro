---
import { site } from "../data/site";
import WhatsAppLink from "./WhatsAppLink.astro";

// Sticky bottom bar for mobile: a single, unambiguous WhatsApp action. Hidden on
// desktop, where the floating WhatsApp button takes over. On the homepage main.js
// arms it so it only reveals once the hero (with its own CTAs) has scrolled away,
// avoiding a stacked, duplicated CTA on the first fold. Without JS it stays
// visible, preserving the no-JS conversion path.
---

<div class="mobile-cta-bar" role="group" aria-label="Acción rápida">
  <WhatsAppLink
    href={site.getWhatsAppHref(site.whatsappDefaultMessage)}
    class="mobile-cta-bar-primary"
    iconFirst={true}
  >
    Agendar evaluación gratis
  </WhatsAppLink>
</div>
