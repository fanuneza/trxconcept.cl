---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  name: string;
  quote: string;
  outcome: string;
}

const { image, name, quote, outcome } = Astro.props;
---

<div class="testimonial-card">
  <div class="testimonial-header">
    <Picture
      src={image}
      alt={name}
      formats={["avif", "webp"]}
      fallbackFormat="webp"
      quality={60}
      widths={[100, 200]}
      sizes="56px"
      pictureAttributes={{ class: "testimonial-img" }}
      loading="eager"
      decoding="async"
    />
    <div class="testimonial-meta">
      <span class="testimonial-author">{name}</span>
      <span class="testimonial-outcome">{outcome}</span>
    </div>
  </div>
  <blockquote class="testimonial-quote">
    <p>{quote}</p>
  </blockquote>
</div>
