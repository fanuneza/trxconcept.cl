<div class="cookie-banner" id="cookie-banner" role="region" aria-live="polite" aria-label="Aviso de cookies">
  <div class="cookie-inner">
    <p class="cookie-text">
      Usamos cookies de análisis (Google Analytics) para mejorar el sitio.
      Puedes aceptar o rechazar su uso.
      <a href="/politica-de-cookies/" class="cookie-policy-link">Política de cookies</a>
    </p>
    <div class="cookie-actions">
      <button class="cookie-btn cookie-btn--accept" id="cookie-accept" type="button">Aceptar</button>
      <button class="cookie-btn cookie-btn--reject" id="cookie-reject" type="button">Rechazar</button>
    </div>
  </div>
</div>
