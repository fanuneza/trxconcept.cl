<aside class="cookie-banner" id="cookie-banner" role="region" aria-live="polite" aria-label="Aviso de cookies">
  <div class="cookie-body">
    <p class="cookie-title">Cookies y analítica</p>
    <p class="cookie-text">
      Uso Google Analytics solo si aceptas la <a href="/politica-de-cookies/" class="cookie-policy-link"
        >política de cookies</a
      >.
    </p>
  </div>
  <div class="cookie-actions">
    <button class="cookie-btn cookie-btn--accept" id="cookie-accept" type="button">Aceptar</button>
    <button class="cookie-btn cookie-btn--reject" id="cookie-reject" type="button">Rechazar</button>
  </div>
</aside>
