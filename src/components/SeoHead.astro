---
import type { SitePage } from '../data/pages';

const { page } = Astro.props as { page: SitePage };
const ogTitle = page.ogTitle ?? page.title;
const ogDescription = page.ogDescription ?? page.description;
const ogImage = page.ogImage ?? 'https://trxconcept.cl/assets/img/og-image.webp';
const ogType = page.ogType ?? 'website';
const twitterCard = page.twitterCard ?? 'summary_large_image';
---

<link rel="canonical" href={page.canonical} />
{page.robots && <meta name="robots" content={page.robots} />}
<meta name="description" content={page.description} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={page.canonical} />
<meta property="og:type" content={ogType} />
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content="TRX Concept - Entrenamiento personal en Santiago" />
<meta property="og:locale" content="es_CL" />
<meta property="og:site_name" content="TRX Concept" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{page.structuredData && (
  <script type="application/ld+json" set:html={JSON.stringify(page.structuredData)} />
)}
{page.breadcrumb && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": page.breadcrumb.map((crumb, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": crumb.name,
      "item": crumb.item
    }))
  })} />
)}
