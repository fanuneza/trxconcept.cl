---
import CookieBanner from "../components/CookieBanner.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import WaSymbol from "../components/WaSymbol.astro";
import { site } from "../data/site";
import type { SitePage } from "../data/pages";
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { buildSchemaGraph } from "../utils/schema";
import ogImage from "../assets/images/og-image.webp";

type PreloadImage = {
  href: string;
  srcset?: string;
  sizes?: string;
};

const { page, preloadImage } = Astro.props as { page: SitePage; preloadImage?: PreloadImage };
const siteCss = readFileSync(join(process.cwd(), "public/assets/css/style.min.css"), "utf-8");

const canonicalUrl = page.canonical || new URL(Astro.url.pathname, site.url).toString();
const noindex = page.robots === "noindex";
const defaultOgImage = new URL(ogImage.src, site.url).toString();
const legacyOgImageUrl = "https://trxconcept.cl/assets/img/og-image.webp";

const replaceImageUrls = (value: unknown): unknown => {
  if (value === legacyOgImageUrl) return defaultOgImage;
  if (Array.isArray(value)) return value.map(replaceImageUrls);

  if (value && typeof value === "object") {
    return Object.fromEntries(
      Object.entries(value as Record<string, unknown>).map(([key, nestedValue]) => [key, replaceImageUrls(nestedValue)])
    );
  }

  return value;
};

const baseGraph = buildSchemaGraph({
  pageType: page.isHome ? "website" : "webpage",
  url: canonicalUrl,
  title: page.title,
  description: page.description,
  breadcrumb: page.breadcrumb,
});

if (page.structuredData) {
  const schema = replaceImageUrls(page.structuredData) as Record<string, unknown>;
  if ("@graph" in schema && Array.isArray(schema["@graph"])) {
    (baseGraph["@graph"] as Record<string, unknown>[]).push(...(schema["@graph"] as Record<string, unknown>[]));
  } else {
    const { "@context": _unusedCtx, ...node } = schema;
    void _unusedCtx;
    (baseGraph["@graph"] as Record<string, unknown>[]).push(node);
  }
}
---

<!doctype html>
<html lang="es" data-ga4-id={site.ga4Id} data-consent-cookie={site.consentCookie}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffd700" />
    <Seo
      title={page.title}
      titleTemplate="%s | TRX Concept"
      description={page.description}
      canonical={canonicalUrl}
      noindex={noindex}
      ogType={page.ogType ?? "website"}
      ogImage={page.ogImage ?? defaultOgImage}
      ogImageAlt={page.title}
      ogImageWidth={1200}
      ogImageHeight={630}
      siteName="TRX Concept"
      locale="es_CL"
      graph={baseGraph}
      twitter={{ card: page.twitterCard ?? "summary_large_image" }}
      extraLinks={[
        { rel: "me", href: site.instagram },
        { rel: "sitemap", type: "application/xml", href: "/sitemap-index.xml" },
      ]}
    />
    <link rel="preload" href="/assets/fonts/anton-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/anton-latin-ext-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link
      rel="preload"
      href="/assets/fonts/montserrat-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/montserrat-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      preloadImage && (
        <link
          rel="preload"
          as="image"
          href={preloadImage.href}
          imagesrcset={preloadImage.srcset}
          imagesizes={preloadImage.sizes}
          fetchpriority="high"
        />
      )
    }
    <style is:inline set:html={siteCss}></style>
    <link rel="shortcut icon" href="/assets/img/favicon.png" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/assets/logos/trx-concept-logo-big.png" />
    <script is:inline defer src="/assets/js/main.js"></script>
  </head>
  <body>
    <WaSymbol />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <script is:inline src="/assets/js/cookie-consent.js" defer></script>
  </body>
</html>
