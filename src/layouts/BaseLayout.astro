---
import CookieBanner from "../components/CookieBanner.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MobileCtaBar from "../components/MobileCtaBar.astro";
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import WaSymbol from "../components/WaSymbol.astro";
import { site } from "../data/site";
import type { SitePage } from "../data/pages";
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { buildSchemaGraph, mergeStructuredData } from "../utils/schema";
import ogImage from "../assets/images/og-image.webp";

type PreloadImage = {
  href: string;
  srcset?: string;
  sizes?: string;
};

interface Props {
  page: SitePage;
  preloadImage?: PreloadImage;
}

const { page, preloadImage } = Astro.props;
const siteCss = readFileSync(join(process.cwd(), "public/assets/css/style.min.css"), "utf-8");

const canonicalUrl = page.canonical || new URL(Astro.url.pathname, site.url).toString();
const noindex = page.robots === "noindex";
const defaultOgImage = new URL(ogImage.src, site.url).toString();

const baseGraph = buildSchemaGraph({
  pageType: page.isHome ? "website" : "webpage",
  url: canonicalUrl,
  title: page.title,
  description: page.description,
  breadcrumb: page.breadcrumb,
});

if (page.structuredData) {
  mergeStructuredData(baseGraph, page.structuredData);
}
---

<!doctype html>
<html
  lang="es"
  data-ga4-id={site.ga4Id}
  data-consent-cookie={site.consentCookie}
  data-wa-default-msg={site.whatsappDefaultMessage}
  data-wa-number={site.whatsappNumber}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <Seo
      title={page.title}
      titleTemplate="%s | TRX Concept"
      description={page.description}
      canonical={canonicalUrl}
      noindex={noindex}
      ogType={page.ogType ?? "website"}
      ogImage={page.ogImage ?? defaultOgImage}
      ogTitle={page.ogTitle ?? page.title}
      ogDescription={page.ogDescription ?? page.description}
      ogImageAlt={page.ogImageAlt ?? "Nicolás Echeverría, entrenador certificado TRX en Santiago"}
      ogImageWidth={1200}
      ogImageHeight={630}
      siteName="TRX Concept"
      locale="es_CL"
      graph={baseGraph}
      twitter={{ card: page.twitterCard ?? "summary_large_image" }}
      extraLinks={[
        { rel: "me", href: site.instagram },
        { rel: "sitemap", type: "application/xml", href: "/sitemap-index.xml" },
      ]}
    />
    <slot name="head" />
    <link
      rel="preload"
      href="/assets/fonts/bebas-neue-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/source-sans-3-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/source-sans-3-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      preloadImage && (
        <link
          rel="preload"
          as="image"
          href={preloadImage.href}
          imagesrcset={preloadImage.srcset}
          imagesizes={preloadImage.sizes}
          fetchpriority="high"
        />
      )
    }
    <style is:inline set:html={siteCss}></style>
    <link rel="icon" href="/assets/img/favicon.png" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/assets/logos/trx-concept-logo-big.png" />
    <script is:inline defer src="/assets/js/main.js"></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <WaSymbol />
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer showCta={!noindex} />
    {!noindex && <MobileCtaBar />}
    <CookieBanner />
    <script is:inline src="/assets/js/cookie-consent.js" defer></script>
  </body>
</html>
