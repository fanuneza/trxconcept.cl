---
import BaseLayout from "../layouts/BaseLayout.astro";

const page = {
  title: "Página no encontrada | TRX Concept",
  description:
    "La página que buscas no existe o fue movida. Vuelve al inicio de TRX Concept o revisa los servicios disponibles.",
  canonical: "https://trxconcept.cl/404.html",
  robots: "noindex",
  content: "",
  isHome: false,
};
---

<BaseLayout page={page}>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">404</p>
      <h1>Página no encontrada</h1>
      <p>La página que buscas no existe o fue movida. Puedes volver al inicio o revisar los servicios disponibles.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/">Volver al inicio</a>
        <a class="btn btn-outline" href="/servicios/">Ver servicios</a>
      </div>
    </div>
  </section>
</BaseLayout>
