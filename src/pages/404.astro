---
import BaseLayout from "../layouts/BaseLayout.astro";
import FuzzyRedirect from "@jdevalk/astro-seo-graph/FuzzyRedirect.astro";
import WhatsAppLink from "../components/WhatsAppLink.astro";
import { WHATSAPP_MESSAGE_EVALUATION } from "../data/site";

const page = {
  title: "Página no encontrada",
  description:
    "La página que buscas no existe o fue movida. Vuelve al inicio de TRX Concept o revisa los servicios disponibles.",
  canonical: "https://trxconcept.cl/404.html",
  robots: "noindex",
  content: "",
  isHome: false,
};
---

<BaseLayout page={page}>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <p>404</p>
      <h1>Página no encontrada</h1>
      <p>
        La página que buscas no existe o fue movida. Puedes volver al inicio, revisar los <a href="/servicios/"
          >servicios</a
        > o escribir si buscabas clases de TRX en Santiago.
      </p>
      <div class="not-found-suggestion">
        <FuzzyRedirect />
      </div>
      <div class="hero-cta">
        <a class="btn btn--primary" href="/">Volver al inicio</a>
        <WhatsAppLink message={WHATSAPP_MESSAGE_EVALUATION} class="btn btn--outline-light">
          Agendar evaluación inicial
        </WhatsAppLink>
      </div>
    </div>
  </section>
</BaseLayout>
