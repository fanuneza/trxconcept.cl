---
import { getImage } from "astro:assets";
import heroImage from "../assets/images/hero.webp";
import HomeContent from "../components/HomeContent.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pages } from "../data/pages";

const page = pages.home;
const heroWidths = [480, 640, 768, 960, 1200, 1440];
const heroQuality = 25;
const heroVariants = await Promise.all(
  heroWidths.map((width) => getImage({ src: heroImage, width, format: "avif", quality: heroQuality }))
);
const preloadImage = {
  href: heroVariants[0].src,
  srcset: heroVariants.map((variant, index) => `${variant.src} ${heroWidths[index]}w`).join(", "),
  sizes: "100vw",
};
---

<BaseLayout page={page} preloadImage={preloadImage}>
  <HomeContent />
</BaseLayout>
