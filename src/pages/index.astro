---
import { getImage } from "astro:assets";
import { makeIds } from "@jdevalk/seo-graph-core";
import heroImage from "../assets/images/hero-new.jpg";
import HomeContent from "../components/HomeContent.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pages } from "../data/pages";
import { site } from "../data/site";

const page = pages.home;
const siteUrl = site.url.endsWith("/") ? site.url : `${site.url}/`;
const ids = makeIds({ siteUrl });
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": ids.website,
  name: site.name,
  alternateName: "trxconcept.cl",
  url: site.url,
};
const heroWidths = [480, 640, 768, 960, 1200, 1440];
const heroQuality = 30;
const heroVariants = await Promise.all(
  heroWidths.map((width) => getImage({ src: heroImage, width, format: "avif", quality: heroQuality }))
);
const preloadImage = {
  href: heroVariants[0].src,
  srcset: heroVariants.map((variant, index) => `${variant.src} ${heroWidths[index]}w`).join(", "),
  sizes: "100vw",
};
---

<BaseLayout page={page} preloadImage={preloadImage}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>
  <HomeContent />
</BaseLayout>
